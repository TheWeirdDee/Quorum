# ─── CROO / CAP ───────────────────────────────────────────────
# Obtain the SDK-Key by registering the Quorum agent + service in the Agent Store dashboard.
# The SDK (@croo-network/sdk@0.2.1) is CUSTODIAL — see SDK_NOTES.md item 1:
# no private key, no chain id, no token address belongs here. Auth is the
# SDK-Key alone; fund the agent by depositing USDC to its AA wallet address
# (shown in the Dashboard) — that's a Dashboard action, not config here.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_API_KEY=            # your Quorum agent's SDK-Key (KEEP SECRET; redacted in logs)
CROO_AGENT_ID=           # optional — omit to use the agent bound to CROO_API_KEY
CROO_RPC_URL=            # optional custom JSON-RPC endpoint; SDK defaults to Base mainnet
CROO_SIMULATE=true       # true (default) = dry-run the hire lifecycle, never call payOrder for real.
                         # Set to false explicitly, deliberately, only when you intend to spend real USDC.

# Timeouts for the two event waits in the requester hire state machine
# (negotiate -> wait order_created -> pay -> wait order_completed -> getDelivery).
# See SDK_NOTES.md item 2 — a counterparty that never accepts/delivers must not hang us.
CROO_ORDER_CREATED_TIMEOUT_MS=90000
CROO_ORDER_COMPLETED_TIMEOUT_MS=300000

# ─── Hired agents (confirm live + IDs in the Agent Store before demo) ───
REPO_DOCTOR_SERVICE_ID=  # "Repo Health Check" service id
VERIS_SERVICE_ID=        # VERIS trust/due-diligence service id
ESCALATION_AGENT_SERVICE_ID=   # Themis "Fact-Check" — confirmed live. Leave empty to degrade gracefully:
                                # honest pre-escalation confidence, no fabrication.
# A DIFFERENT buyer key is used for outbound hires than the provider key, so calls count as unique counterparties:
CROO_BUYER_API_KEY=

# ─── Escalation engine (SPEC §7, FR-14/15/16) — Themis is the confirmed tiebreaker ──
ESCALATION_ASSUMED_COST_USDC=0.03      # pre-hire budget-cap estimate only; real cost always comes from the actual hire
ESCALATION_MIN_DECISIVENESS=0.1        # below this |score-0.5|*2, Themis is treated as inconclusive — no change made
ESCALATION_MAX_ATTEMPTS=1              # M4 only ever buys one; kept configurable per SPEC §7

# ─── Per-hire price guard (SDK_NOTES item 23) ──────────────────
# Providers quote dynamically at accept time — a real VERIS negotiation once
# quoted $20 for its $0.10-listed service. The ACTUAL quote on the created
# order is checked against these caps before payOrder; an over-cap quote is
# refused (order left unpaid to expire) and reported as a structured failure.
REPO_DOCTOR_MAX_COST_USDC=0.05   # list $0.01
VERIS_MAX_COST_USDC=0.50         # list $0.10
ESCALATION_MAX_COST_USDC=0.15    # Themis list ~$0.01-0.03

# ─── Event detection sources ──────────────────────────────────
GITHUB_TOKEN=            # free PAT for GitHub REST + Advisory GraphQL (higher rate limits)
OSV_API_URL=https://api.osv.dev/v1/query
NPM_REGISTRY_URL=https://registry.npmjs.org
POLL_INTERVAL_MINUTES=15
BASELINE_SCAN_MAX_DEPS=40   # caps deps polled per sweep (production-first) — bounds both the M5 baseline scan's delivery window and each poll cycle's OSV/npm/GitHub load

# ─── Notifications ────────────────────────────────────────────
SLACK_WEBHOOK_URL=       # demo alert target

# ─── Dashboard read API ────────────────────────────────────────
# Only needed if the dashboard is deployed SEPARATELY from this worker (e.g.
# dashboard on Vercel, worker on Render/Railway/Fly) — they share no
# filesystem, so the dashboard can't read agent/quorum.db directly and
# instead calls the worker's own read-only HTTP API. Local dev / a
# co-located deploy can leave all three blank (dashboard falls back to a
# direct file read).
DASHBOARD_API_PORT=8080     # agent-side: the worker's own read API port
DASHBOARD_API_KEY=          # agent-side: shared secret; empty = read API refuses every request
# Dashboard-side (set these in the DASHBOARD's own env, e.g. Vercel project settings — NOT agent/.env):
#   QUORUM_AGENT_API_URL=https://quorum-veht.onrender.com   (Render public URL; no :8080)
#   QUORUM_AGENT_API_KEY=<same value as DASHBOARD_API_KEY above>

# ─── State ────────────────────────────────────────────────────
# Local: file:./quorum.db
# Render Free: Neon's pooled postgresql:// URL (keep it secret; never commit it)
DATABASE_URL=file:./quorum.db

# ─── Dev / offline mode ────────────────────────────────────────
USE_FIXTURES=false      # true = engine reads fixtures/ instead of live network calls; no spend
LOG_LEVEL=info           # debug | info | warn | error

# ─── Risk policies (SPEC §5) — confidence target, budget cap, escalation aggressiveness ───
RISK_POLICY_STARTUP_CONFIDENCE_TARGET=0.70
RISK_POLICY_STARTUP_BUDGET_CAP_USDC=0.05
RISK_POLICY_STARTUP_ESCALATION_AGGRESSIVENESS=rarely

RISK_POLICY_BALANCED_CONFIDENCE_TARGET=0.80
RISK_POLICY_BALANCED_BUDGET_CAP_USDC=0.15
RISK_POLICY_BALANCED_ESCALATION_AGGRESSIVENESS=on_disagreement

RISK_POLICY_ENTERPRISE_CONFIDENCE_TARGET=0.90
RISK_POLICY_ENTERPRISE_BUDGET_CAP_USDC=0.25
RISK_POLICY_ENTERPRISE_ESCALATION_AGGRESSIVENESS=on_uncertainty
